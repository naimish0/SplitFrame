    <string name="privacy_policy">Privacy policy</string>
    <string name="privacy_effective_date">Effective July 18, 2026</string>
    <string name="privacy_intro">SplitFrame is an on-device photo and video editing app. This notice explains what the app stores, what Google may process to provide advertising, and the controls available to you.</string>
    <string name="privacy_media_title">Photos and videos</string>
    <string name="privacy_media_body">SplitFrame accesses only media that you select with the Android system picker. Editing and image processing happen on your device. Selected media is not uploaded to a SplitFrame server. Video export uses a temporary file in the app cache and removes it after the export attempt.</string>
    <string name="privacy_storage_title">On-device storage and retention</string>
    <string name="privacy_storage_body">The app stores editing preferences, favorite templates, recent export references, and video projects in its private database. These records can include local content URIs. Video projects can be deleted in the app; preferences, favorites, and export history remain until you clear the app storage or uninstall the app. App backup is disabled. Exported images and videos remain in your gallery until you delete them.</string>
    <string name="privacy_ads_title">Advertising and consent</string>
    <string name="privacy_ads_body">SplitFrame uses Google Mobile Ads. Google may process an IP address, approximate location derived from it, device or advertising identifiers, ad interactions, and diagnostic information to deliver and measure ads and prevent fraud. Your selected photos and videos are not provided to Google for advertising. Where required, ads are requested only after the Google consent flow permits them.</string>
    <string name="manage_ad_privacy">Manage advertising privacy</string>
    <string name="google_privacy_policy">Read Google privacy policy</string>
    <string name="privacy_permissions_title">Permissions</string>
    <string name="privacy_permissions_body">On Android 7 through 9, storage permission is requested only when you save an export to shared media storage. On Android 13 and later, notification permission may be requested so a long-running video export can show progress. You can change permissions in Android settings.</string>
    <string name="privacy_choices_title">Your choices and deletion</string>
    <string name="privacy_choices_body">Use Manage advertising privacy when it is shown to review available ad choices. You can clear SplitFrame data or uninstall the app to remove its private records. Delete exported files through your gallery or file manager. Google controls retention of information processed by its advertising services.</string>
    <string name="privacy_security_title">Security</string>
    <string name="privacy_security_body">Private app data is protected by the Android application sandbox and is excluded from backup. Network data handled by Google Mobile Ads is encrypted in transit. No method of storage or transmission can be guaranteed completely secure.</string>
    <string name="privacy_children_title">Children</string>
    <string name="privacy_children_body">SplitFrame is not designed for children under 13. The publisher does not knowingly collect personal information directly from children.</string>
    <string name="privacy_contact_title">Contact</string>
    <string name="privacy_contact_body">For privacy questions, use the developer contact shown on the SplitFrame Google Play listing.</string>
    <string name="storage_permission_required">Storage permission is required to save exports on Android 7 through 9.</string>
    <string name="video_notification_permission_title">Video export notifications</string>
    <string name="video_notification_permission_body">Allow notifications to keep video export progress visible while SplitFrame works in the background. You can continue without allowing notifications.</string>
